# Database Configuration
DATABASE_URL=database url
TEST_DATABASE_URL=postgresql+asyncpg://user:pass@host/test_db?ssl=require

# Authentication (T020: Better Auth Integration)
# IMPORTANT: Must match frontend BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=BETTER AUTH SECRET

# Better Auth JWT Configuration (T020)
# For local development, use frontend URL (Better Auth runs on frontend)
BETTER_AUTH_JWKS_URL=http://localhost:3000/.well-known/jwks.json
BETTER_AUTH_ISSUER=http://localhost:3000
# For production, replace with your deployed frontend URL

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
FRONTEND_URL=http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8001
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
