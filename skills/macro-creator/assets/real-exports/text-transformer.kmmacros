		<key>Macros</key>
		<array>
			<dict>
				<key>Actions</key>
				<array>
					<dict>
						<key>ActionUID</key>
						<integer>999381266</integer>
						<key>DisplayKind</key>
						<string>Window</string>
						<key>HonourFailureSettings</key>
						<true/>
						<key>IncludeStdErr</key>
						<false/>
						<key>IncludedVariables</key>
						<array>
							<string>9999</string>
						</array>
						<key>MacroActionType</key>
						<string>ExecuteShellScript</string>
						<key>Path</key>
						<string></string>
						<key>Source</key>
						<string>Nothing</string>
						<key>Text</key>
						<string>#!/bin/bash

# Get the frontmost application BEFORE showing dialog
frontmost_app=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true')

# Save original clipboard
original_clip=$(pbpaste)

# Copy selected text
osascript -e 'tell application "System Events" to keystroke "c" using command down'
sleep 0.2

# Get selected text
selected=$(pbpaste)

# Validate we got text
if [ -z "$selected" ] || [ "$selected" = "$original_clip" ]; then
	osascript -e 'display notification "No text selected" with title "Text Transformer"'
	echo "$original_clip" | pbcopy
	exit 0
fi

# Get transformation choice
choice=$(osascript &lt;&lt;'EOF'
tell application "Keyboard Maestro Engine"
	set theChoice to choose from list {"Title Case", "UPPERCASE", "lowercase", "Sentence case", "slug-case", "camelCase"} with prompt "Transform text to:" default items {"Title Case"}
	if theChoice is false then
		return ""
	else
		return item 1 of theChoice
	end if
end tell
EOF
)

# If user cancelled, restore clipboard and exit
if [ -z "$choice" ]; then
	echo "$original_clip" | pbcopy
	exit 0
fi

# Transform based on choice
case "$choice" in
	"Title Case")
		result=$(echo "$selected" | awk '{for(i=1;i&lt;=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')
		;;
	"UPPERCASE")
		result=$(echo "$selected" | tr '[:lower:]' '[:upper:]')
		;;
	"lowercase")
		result=$(echo "$selected" | tr '[:upper:]' '[:lower:]')
		;;
	"Sentence case")
		first_char=$(echo "$selected" | cut -c1 | tr '[:lower:]' '[:upper:]')
		rest=$(echo "$selected" | cut -c2- | tr '[:upper:]' '[:lower:]')
		result="${first_char}${rest}"
		;;
	"slug-case")
		result=$(echo "$selected" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
		;;
	"camelCase")
		result=""
		first_word=true
		for word in $selected; do
			if [ "$first_word" = true ]; then
				result=$(echo "$word" | tr '[:upper:]' '[:lower:]')
				first_word=false
			else
				first_char=$(echo "$word" | cut -c1 | tr '[:lower:]' '[:upper:]')
				rest=$(echo "$word" | cut -c2- | tr '[:upper:]' '[:lower:]')
				result="${result}${first_char}${rest}"
			fi
		done
		;;
esac

# Put transformed text in clipboard
echo -n "$result" | pbcopy

# CRITICAL: Reactivate the original app
osascript -e "tell application \"$frontmost_app\" to activate"
sleep 0.2

# Paste (this will replace the original selection since we just reactivated)
osascript -e 'tell application "System Events" to keystroke "v" using command down'
sleep 0.1

# Restore original clipboard
echo "$original_clip" | pbcopy</string>
						<key>TimeOutAbortsMacro</key>
						<true/>
						<key>TrimResults</key>
						<true/>
						<key>TrimResultsNew</key>
						<true/>
						<key>UseText</key>
						<true/>
					</dict>
				</array>
