												<key>ActionName</key>
												<string>Prompt for Icon Name</string>
												<key>ActionUID</key>
												<integer>999442930</integer>
												<key>Buttons</key>
												<array>
													<dict>
														<key>Button</key>
														<string>OK</string>
													</dict>
													<dict>
