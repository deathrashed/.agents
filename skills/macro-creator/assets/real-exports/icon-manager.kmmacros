													<dict>
														<key>ActionName</key>
														<string>Get App Icon Path</string>
														<key>ActionUID</key>
														<integer>999442934</integer>
														<key>DisplayKind</key>
														<string>Variable</string>
														<key>HonourFailureSettings</key>
														<true/>
														<key>IncludeStdErr</key>
														<false/>
														<key>IncludedVariables</key>
														<array>
