							<dict>
								<key>ActionName</key>
								<string>Check for Large Files and Resize if Necessary</string>
								<key>ActionUID</key>
								<integer>999442964</integer>
								<key>DisplayKind</key>
								<string>None</string>
								<key>HonourFailureSettings</key>
								<true/>
								<key>IncludeStdErr</key>
								<false/>
								<key>IncludedVariables</key>
