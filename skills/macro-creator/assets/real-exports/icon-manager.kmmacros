					<dict>
						<key>ActionName</key>
						<string>Icon Chooser or New Custom Icon?</string>
						<key>ActionUID</key>
						<integer>999442922</integer>
						<key>Conditions</key>
						<dict>
							<key>ConditionList</key>
							<array>
								<dict>
									<key>ConditionType</key>
									<string>Text</string>
