					<dict>
						<key>ActionName</key>
						<string>Check to see if Typinator window is on screen and position prompt list accordingly</string>
						<key>ActionUID</key>
						<integer>999330401</integer>
						<key>Actions</key>
						<array>
							<dict>
								<key>ActionName</key>
								<string>Execute AppleScript to check for Typinator window and get it's size and position</string>
								<key>ActionUID</key>
								<integer>999330402</integer>
								<key>DisplayKind</key>
								<string>Window</string>
								<key>HonourFailureSettings</key>
								<true/>
								<key>IncludeStdErr</key>
								<false/>
								<key>IncludedVariables</key>
								<array>
									<string>9999</string>
								</array>
								<key>MacroActionType</key>
								<string>ExecuteAppleScript</string>
								<key>Path</key>
								<string></string>
								<key>Text</key>
								<string>----------------------------------------------------------# Author:				Chris Thomerson (@cdthomer)## Current Version:		1.0 (Initial script)# Version History:			1.0 (Initial script)## Created:				Wednesday, February 2, 2022# Modified:				Wednesday, February 2, 2022# macOS:				11.6.3 (Big Sur)# Tags:					Typinator## DISCLAIMER# Permission to use, copy, modify, and/or distribute this# software for any purpose with or without fee is hereby granted.## THE SOFTWARE IS PROVIDED "AS IS" AND THE AUTHOR DISCLAIMS ALL# WARRANTIES WITH REGARD TO THIS SOFTWARE INCLUDING ALL IMPLIED# WARRANTIES OF MERCHANTABILITY AND FITNESS. IN NO EVENT SHALL# THE AUTHOR BE LIABLE FOR ANY SPECIAL, DIRECT, INDIRECT, OR# CONSEQUENTIAL DAMAGES OR ANY DAMAGES WHATSOEVER RESULTING FROM# LOSS OF USE, DATA OR PROFITS, WHETHER IN AN ACTION OF CONTRACT,# NEGLIGENCE OR OTHER TORTIOUS ACTION, ARISING OUT OF OR IN# CONNECTION WITH THE USE OR PERFORMANCE OF THIS SOFTWARE.------------------------------------------------------------set AppleScript variablesset winName to "Create new Typinator Item"tell application "System Events"	tell application process "Typinator"				--determine if the Typinator window exists		if window winName exists then			set typWinExists to "true"						--getTypinator window position			tell window winName				set {typXsize, typYsize} to its size				set {typXpos, typYpos} to its position			end tell						### Requires Keyboard Maestro 8.0.3+ ###			set kmInst to system attribute "KMINSTANCE"			tell application "Keyboard Maestro Engine"				setvariable "local__typWinExists" instance kmInst to typWinExists				setvariable "local__typXsize" instance kmInst to typXsize				setvariable "local__typYsize" instance kmInst to typYsize				setvariable "local__typXpos" instance kmInst to typXpos				setvariable "local__typYpos" instance kmInst to typYpos			end tell					else			--set typWinExists to "false"		end if			end tellend tell</string>
								<key>TimeOutAbortsMacro</key>
								<true/>
								<key>TrimResults</key>
								<true/>
								<key>TrimResultsNew</key>
								<true/>
								<key>UseText</key>
								<true/>
							</dict>
							<dict>
								<key>ActionName</key>
								<string>Position spell check prompt list</string>
								<key>ActionUID</key>
								<integer>999330403</integer>
								<key>CaseEntries</key>
								<array>
									<dict>
										<key>Actions</key>
										<array>
											<dict>
												<key>Action</key>
												<string>MoveWindowTo</string>
												<key>ActionUID</key>
												<integer>999330404</integer>
												<key>HeightExpression</key>
												<string>300</string>
												<key>HorizontalExpression</key>
												<string>local__typXpos+local__typXsize+10</string>
												<key>MacroActionType</key>
												<string>SetNextEngineWindow</string>
												<key>VerticalExpression</key>
												<string>local__typYpos</string>
												<key>WidthExpression</key>
												<string>300</string>
											</dict>
										</array>
										<key>ConditionType</key>
										<string>Is</string>
										<key>TestValue</key>
										<string>true</string>
									</dict>
									<dict>
