						<string>### Requires Keyboard Maestro 8.0.3+ ###set kmInst to system attribute "KMINSTANCE"tell application "Keyboard Maestro Engine"	set filePathToCopy to getvariable "Local__FilePath" instance kmInstend tellset the clipboard to POSIX file filePathToCopy</string>
