						<false/>
						<key>Text</key>
						<string>set firewall_status to do shell script "defaults read /Library/Preferences/com.apple.alf globalstate"
if firewall_status is less than "2" then
	do shell script "/usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate on --setblockall on --setstealthmode on" with administrator privileges
	"Firewall is now On"
else
	do shell script "/usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate off" with administrator privileges
	"Firewall is now off"
end if
</string>
