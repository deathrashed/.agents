														<key>Text</key>
														<string>function applyRegexReplacement(text, regexSpec) {
    const match = regexSpec.match(/^\/(.+)\/([a-z]*),\s*["']?(.+?)["']?$/);
    
    if (match) {
        const regexPattern = match[1];
        const flags = match[2];
        const replacement = match[3];

        const regex = new RegExp(regexPattern, flags);
        return text.replace(regex, replacement);
    } else {
        return "𝗘𝗥𝗥𝗢𝗥: Invalid regex specification";
    }
}

const text = kmvar.local__Text_to_Insert;
const regexSpec = kmvar.local__RegEx_Pattern;

const newText = applyRegexReplacement(text, regexSpec);
return newText;</string>
