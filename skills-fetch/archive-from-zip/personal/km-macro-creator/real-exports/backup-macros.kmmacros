								<key>Path</key>
								<string></string>
								<key>Text</key>
								<string>--Disabled loop to avoid -600 errors as it was very slow!
--set apscDone1 to false--set loopCount1 to 0--repeat until apscDone1 is true or loopCount1 is 15--	try--if application "Keyboard Maestro Engine" is not running then tell application "Keyboard Maestro Engine" to launchtell application "System Events"	try		set isKMvisible to visible of process "Keyboard Maestro"	on error		set isKMvisible to "KM not active"	end tryend tellset kmInst to system attribute "KMINSTANCE"tell application "Keyboard Maestro Engine"	setvariable "instance_KMappStatus" instance kmInst to isKMvisible	-- will be either true (visible) false (hidden) or "KM not active" (not running)end tell--		set apscDone1 to true--	on error--		set apscDone1 to false--		set loopCount1 to loopCount1 + 1--	end try--end repeat</string>
