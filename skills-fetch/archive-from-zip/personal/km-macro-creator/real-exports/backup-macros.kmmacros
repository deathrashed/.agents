												<string>&lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
	&lt;head&gt;
		&lt;meta charset="utf-8" /&gt;
		&lt;title&gt;MacroBackerUpper&lt;/title&gt;
		&lt;style type="text/css"&gt;
			body {
				font-family: -apple-system;
				font-size: 14px;
				opacity: 1;
				transition: opacity 2s ease-in-out;
			}
		&lt;/style&gt;
	&lt;/head&gt;
	&lt;body data-kmwindowid="theSplash" style="background: #e6ffac"&gt;
		&lt;script&gt;
			function KMWindow() {
				//fromleft, fromtop, width, height
				return "460,300";
			}

			// Close the window with fade-out after 2 seconds
			setTimeout(function () {
				document.body.style.opacity = 0;
				setTimeout(function () {
					window.close();
				}, 300); // Wait for the transition to complete before closing
			}, 300);
		&lt;/script&gt;
	&lt;/body&gt;
&lt;/html&gt;
</string>
