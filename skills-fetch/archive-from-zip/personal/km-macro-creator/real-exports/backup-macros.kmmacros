&lt;html lang="en"&gt;
	&lt;head&gt;
		&lt;meta charset="utf-8" /&gt;
		&lt;title&gt;MacroBackerUpper&lt;/title&gt;
		&lt;style type="text/css"&gt;
            body {
                font-family: -apple-system;
                font-size: 14px;
                margin: 0;
                padding: 0;
            }

            .container {
                width: 460px;
                margin: 0 auto;
		   text-align: left;
            }

            .clock {
                font-family: Menlo, monospace;
                font-size:30px;
		   color: blue;
                text-align: center;
		   margin-top: 20px;
            }

            .fade-in { animation: fadeIn 1s; }
                @keyframes fadeIn {
                0% { opacity: 0; }
                100% { opacity: 100; }
            }

            table {
                width: 70%;
                margin: 0 auto;
            }

            th, td {
                text-align: left;
                padding: 2px;
            }
		&lt;/style&gt; 
	&lt;/head&gt;
	&lt;body data-kmwindowid="theTimerWindow" style="background: #e6ffac"&gt;
        &lt;div class="container fade-in"&gt;
            &lt;br&gt;
            &lt;table border="0" cellpadding="0"&gt;
		&lt;tr&gt;
			&lt;th colspan="2" style="padding-bottom:18px"&gt;&lt;b&gt;Press the specified key to…&lt;/b&gt;&lt;/th&gt;
		&lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;Control&lt;/td&gt;
                &lt;td&gt;Open Settings Manager&lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td style="text-align: center; color:#d5d5d5;" colspan="2"&gt;────────────&lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td style="font-size:85%"&gt;Option&lt;/td&gt;
                &lt;td style="font-size:85%"&gt;Check for updates&lt;/td&gt;
              &lt;/tr&gt;
		%Variable%local_CommandKey%
              &lt;tr&gt;
                &lt;td style="font-size:85%"&gt;Escape&lt;/td&gt;
                &lt;td style="font-size:85%"&gt;Cancel macro&lt;/td&gt;
              &lt;/tr&gt;
		&lt;tr&gt;
			&lt;td colspan="2" style="text-align: center; font-size:smaller; padding-top:20px; color: blue"&gt;&lt;b&gt;Backup starts when the timer expires…&lt;/b&gt;&lt;/td&gt;
		&lt;/tr&gt;
            &lt;/table&gt;
          &lt;/div&gt;

		&lt;p class="clock fade-in"&gt;&lt;span id="counter"&gt;%Variable%instance_TimerDelay%&lt;/span&gt;&lt;/p&gt;

		&lt;script&gt;
			setInterval(function () {
				countdown();
			}, 1000);

			function countdown() {
				let i = document.querySelector('#counter');

				i.innerHTML = parseInt(i.innerHTML) - 1;
				if (parseInt(i.innerHTML) &lt;= 0) {
					window.close();
				}
			}
			
			function KMWindow() {
			 //fromleft, fromtop, width, height
			 return "460,304";
			}

			document.addEventListener("keydown", function(event) {
				if (event.ctrlKey) {
					window.close();
                			window.KeyboardMaestro.Submit('Settings')
				}
				if (event.metaKey) {
					window.close();
                			window.KeyboardMaestro.Submit('Diff')
				}
				if (event.altKey) {
					window.close();
                			window.KeyboardMaestro.Submit('Update')
				}
				if (event.key === "Escape") {
					window.close();
                			window.KeyboardMaestro.Submit('Cancel')
				}
				//if (event.key === "Escape") {
				//	event.preventDefault(); // Prevent the default behavior of the "Escape" key
				//}
			});

		&lt;/script&gt;
	&lt;/body&gt;
&lt;/html&gt;</string>
