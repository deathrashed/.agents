										<key>Text</key>
										<string>&lt;html&gt;
	&lt;head&gt;
             &lt;title&gt;MacroBackerUpper progress&lt;/title&gt;
		&lt;style = "text/css"&gt;
			body {
				font-family: -apple-system;
				font-size: 12px;
			}
			.notdone {
				color: #d5d5d5;
			}
			.done {
				color: black;
			}
			table {
				border-collapse: collapse;
				width: 100%;
				font-size: 13px;
			}

			td {
				padding: 1px;
				color: #d5d5d5;
      			}

      			td:first-child {
        			width: 5%;
      			}
		&lt;/style&gt;
		&lt;script&gt;
			function KMWindow() {
				return "%Variable%local_winDimensions%";
			}
			document.addEventListener("keydown", function(event) {
				if (event.key === "Escape") {
					event.preventDefault(); // Prevent the default behavior of the "Escape" key
				}
			});
		&lt;/script&gt;
	&lt;/head&gt;	
	&lt;body data-kmwindowid="TaskListWindow"&gt;
		&lt;div id="theList"&gt;
			&lt;table id="TheTable"&gt;
				%Variable%instance_TheFullListTable%
			&lt;/table&gt;
		&lt;/div&gt;
	&lt;/body&gt;
&lt;/html&gt;</string>
